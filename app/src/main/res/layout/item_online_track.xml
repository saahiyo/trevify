<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="80dp"
    android:paddingHorizontal="16dp"
    android:paddingVertical="8dp"
    android:foreground="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/onlineArtCard"
        android:layout_width="60dp"
        android:layout_height="60dp"
        app:cardCornerRadius="14dp"
        app:cardElevation="2dp"
        app:strokeWidth="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/onlineAlbumArt"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:background="@color/surface_variant" />
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/onlineTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="8dp"
        android:maxLines="1"
        android:ellipsize="end"
        android:textColor="@color/text_primary"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/onlineArtist"
        app:layout_constraintEnd_toStartOf="@+id/onlinePlayBtn"
        app:layout_constraintStart_toEndOf="@+id/onlineArtCard"
        app:layout_constraintTop_toTopOf="@+id/onlineArtCard"
        app:layout_constraintVertical_chainStyle="packed"
        tools:text="Faded" />

    <TextView
        android:id="@+id/onlineArtist"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:maxLines="1"
        android:ellipsize="end"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        app:layout_constraintBottom_toBottomOf="@+id/onlineArtCard"
        app:layout_constraintEnd_toStartOf="@+id/onlineDuration"
        app:layout_constraintStart_toStartOf="@+id/onlineTitle"
        app:layout_constraintTop_toBottomOf="@+id/onlineTitle"
        tools:text="Alan Walker" />

    <TextView
        android:id="@+id/onlineDuration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="4dp"
        android:textColor="@color/blue"
        android:textSize="11sp"
        android:textStyle="bold"
        android:alpha="0.8"
        app:layout_constraintBottom_toBottomOf="@+id/onlineArtist"
        app:layout_constraintEnd_toStartOf="@+id/onlinePlayBtn"
        app:layout_constraintTop_toTopOf="@+id/onlineArtist"
        tools:text="3:32" />

    <ImageView
        android:id="@+id/onlinePlayBtn"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:padding="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/ic_play_arrow_24"
        app:tint="@color/blue" />

</androidx.constraintlayout.widget.ConstraintLayout>
